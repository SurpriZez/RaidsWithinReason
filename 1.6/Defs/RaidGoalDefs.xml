    <targetDescription>take a colonist prisoner</targetDescription>
    <successGoodwillDelta>0</successGoodwillDelta>
    <failureGoodwillDelta>-5</failureGoodwillDelta>
    <retreatOnSuccess>true</retreatOnSuccess>
  </RaidsWithinReason.RaidGoalDef>

  <RaidsWithinReason.RaidGoalDef>
    <defName>RaidGoal_Destroy</defName>
