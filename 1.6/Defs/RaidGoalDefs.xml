<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <RaidsWithinReason.RaidGoalDef>
    <defName>RaidGoal_Loot</defName>
    <label>loot</label>
    <goalType>Loot</goalType>
    <targetDescription>steal silver and other valuables</targetDescription>
    <successGoodwillDelta>5</successGoodwillDelta>
    <failureGoodwillDelta>-3</failureGoodwillDelta>
    <retreatOnSuccess>true</retreatOnSuccess>
  </RaidsWithinReason.RaidGoalDef>

  <RaidsWithinReason.RaidGoalDef>
    <defName>RaidGoal_Capture</defName>
    <label>capture</label>
