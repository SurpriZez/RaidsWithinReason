    <targetDescription>demolish the colony's finest bedroom</targetDescription>
    <successGoodwillDelta>-2</successGoodwillDelta>
    <failureGoodwillDelta>-8</failureGoodwillDelta>
    <retreatOnSuccess>false</retreatOnSuccess>
  </RaidsWithinReason.RaidGoalDef>

  <RaidsWithinReason.RaidGoalDef>
    <defName>RaidGoal_Revenge</defName>
    <label>revenge</label>
    <goalType>Revenge</goalType>
    <targetDescription>kill the colony's best fighter in retaliation</targetDescription>
    <successGoodwillDelta>-10</successGoodwillDelta>
    <failureGoodwillDelta>-15</failureGoodwillDelta>
    <retreatOnSuccess>true</retreatOnSuccess>
  </RaidsWithinReason.RaidGoalDef>

